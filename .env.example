# Environment variables for DR Screening System

# Weights & Biases
WANDB_API_KEY=your_wandb_api_key_here

# Database
DB_PASSWORD=secure_database_password

# Grafana
GRAFANA_PASSWORD=admin_password

# Model Path (optional, defaults to models/checkpoints/best_model.ckpt)
MODEL_PATH=models/checkpoints/best_model.ckpt

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging Level
LOG_LEVEL=INFO
